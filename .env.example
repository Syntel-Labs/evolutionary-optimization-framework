# ==========================================================
# Archivo de ejemplo de variables de entorno a nivel monorepo
#
# Copiar a .env y rellenar con valores reales:
#   cp .env.example .env
#
# Este archivo documenta TODAS las variables compartidas entre
# servicios (web, engine, postgres). Variables especificas de
# cada app viven en apps/<app>/.env.example.
#
# Regla: .env y .env.example deben estar siempre sincronizados.
# ==========================================================

# ----------------------------------------------------------
# Identidad del stack en docker (prefijo host-visible)
# ----------------------------------------------------------
# Se usa como nombre del proyecto compose y prefijo de todo lo que
# se ve desde el host: contenedores, red y volumenes.
# Cambiar si necesitas correr varios stacks paralelos en la misma
# maquina (ej. evopfr-dev, evopfr-staging).
COMPOSE_PROJECT_PREFIX=evopfr

# ----------------------------------------------------------
# Entorno de ejecucion
# ----------------------------------------------------------
# Valores permitidos: development | staging | production
NODE_ENV=development
APP_ENV=development

# ----------------------------------------------------------
# Puertos expuestos en el host (docker compose)
# ----------------------------------------------------------
WEB_PORT=3000
ENGINE_PORT=8000
POSTGRES_PORT=5432

# ----------------------------------------------------------
# Hosts internos (nombres de servicio en la red de docker)
# ----------------------------------------------------------
WEB_HOST=web
ENGINE_HOST=engine
POSTGRES_HOST=postgres

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_DB=eof_db
POSTGRES_USER=eof_user
POSTGRES_PASSWORD=change_me_in_local

# URL compuesta usada por Prisma y el motor
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://eof_user:change_me_in_local@postgres:5432/eof_db

# ----------------------------------------------------------
# Dashboard (Next.js) -> motor (FastAPI)
# ----------------------------------------------------------
# URL publica que el navegador usa para llamar al motor
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
# URL interna server-to-server dentro de docker
ENGINE_INTERNAL_URL=http://engine:8000

# ----------------------------------------------------------
# Motor (FastAPI)
# ----------------------------------------------------------
ENGINE_LOG_LEVEL=info
ENGINE_CORS_ORIGINS=http://localhost:3000

# Limite de tiempo por defecto del solver ILP en segundos
ENGINE_ILP_DEFAULT_TIME_LIMIT=3600

# Numero de workers para el GA paralelo (0 = auto = cpu_count)
ENGINE_GA_WORKERS=0
