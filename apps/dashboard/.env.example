# ==========================================================
# Variables especificas del dashboard (Next.js)
#
# Las variables compartidas con el resto del monorepo viven en
# la raiz del repo (.env.example). Aqui solo van las que son
# exclusivas del front.
# ==========================================================

# Puerto del servidor Next.js (controlable, sin default en codigo)
WEB_PORT=3000

# URL publica del motor (visible desde el navegador)
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# Locale por defecto de la app. Valores: es | en
NEXT_PUBLIC_DEFAULT_LOCALE=es
