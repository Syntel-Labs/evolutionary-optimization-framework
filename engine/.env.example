# ==========================================================
# Variables especificas del motor (FastAPI)
#
# Variables compartidas (DB, puertos, hosts) en el .env raiz.
# ==========================================================

# Puerto del servidor FastAPI
ENGINE_PORT=8000

# Nivel de logs del motor: debug | info | warning | error
ENGINE_LOG_LEVEL=info

# Origenes permitidos por CORS separados por coma
ENGINE_CORS_ORIGINS=http://localhost:3000

# Limite de tiempo por defecto del solver ILP en segundos
ENGINE_ILP_DEFAULT_TIME_LIMIT=3600

# Workers del GA paralelo (0 = auto basado en cpu_count)
ENGINE_GA_WORKERS=0

# Conexion a postgres (la inyecta el .env raiz o docker compose)
DATABASE_URL=postgresql://eof_user:change_me_in_local@postgres:5432/eof_db
